flowchart TD
    START["Project entry points"] --> PS["push_swap"]
    START --> CH["checker (bonus)"]

    subgraph MANDATORY["Mandatory flow"]
        PS --> M0{"ac < 2?"}
        M0 -- "yes" --> MEXIT["Exit silently"]
        M0 -- "no" --> M1["parse_arguments"]

        M1 --> M2{"ac == 2?"}
        M2 -- "yes" --> M3["ft_split quoted string"]
        M2 -- "no" --> M4["walk argv one by one"]

        M3 --> M5["validate each token"]
        M4 --> M5
        M5 --> M6["is_valid_number -> ft_atoi -> int range"]
        M6 --> M7["append node to stack A"]
        M7 --> M8["has_duplicates"]
        M8 --> M9["assign_index 0..n-1"]
        M9 --> M10{"already sorted?"}

        M10 -- "yes" --> M11["free stack A and exit"]
        M10 -- "no" --> M12{"size selector"}

        M12 -- "2" --> S2["sort_two: sa if needed"]
        M12 -- "3" --> S3["sort_three: index-pattern sort"]
        M12 -- "4" --> S4["sort_four: min to top -> pb -> sort_three -> pa"]
        M12 -- "5" --> S5["sort_five: min to top -> pb -> sort_four -> pa"]
        M12 -- "> 5" --> B0["butterfly_sort"]

        B0 --> B1["chunk_size = get_chunk_size(size)"]
        B1 --> B2["next_index = 0"]
        B2 --> B3{"stack A empty?"}

        B3 -- "no" --> B4{"top index <= next_index?"}
        B4 -- "yes" --> B5["pb -> rb -> next_index++"]
        B4 -- "no" --> B6{"top index <= next_index + chunk_size?"}
        B6 -- "yes" --> B7["pb -> next_index++"]
        B6 -- "no" --> B8["ra"]

        B5 --> B3
        B7 --> B3
        B8 --> B3

        B3 -- "yes" --> B9["push_all_to_a"]
        B9 --> B10{"stack B empty?"}
        B10 -- "no" --> B11["find_max_index + get_position"]
        B11 --> B12{"rb cheaper than rrb?"}
        B12 -- "yes" --> B13["rotate B with rb"]
        B12 -- "no" --> B14["rotate B with rrb"]
        B13 --> B15["pa"]
        B14 --> B15
        B15 --> B10

        S2 --> DONE["sorted stack A"]
        S3 --> DONE
        S4 --> DONE
        S5 --> DONE
        B10 -- "yes" --> DONE
    end

    subgraph BONUS["Bonus checker flow"]
        CH --> C0{"ac < 2?"}
        C0 -- "yes" --> CEXIT["Exit silently"]
        C0 -- "no" --> C1["parse_arguments (same validation path)"]
        C1 --> C2["read one instruction from stdin"]
        C2 --> C3{"EOF?"}
        C3 -- "yes" --> C7{"A sorted and B empty?"}
        C3 -- "no" --> C4{"empty line?"}
        C4 -- "yes" --> CERR["error_exit -> Error"]
        C4 -- "no" --> C5["checker_execute"]
        C5 --> C6{"valid opcode?"}
        C6 -- "no" --> CERR
        C6 -- "yes" --> C2
        C7 -- "yes" --> COK["print OK"]
        C7 -- "no" --> CKO["print KO"]
    end

    style START fill:#ffd9e8,stroke:#c04a76,stroke-width:2px
    style MANDATORY fill:#fff7d6,stroke:#caa400,stroke-width:1px
    style BONUS fill:#dff4ff,stroke:#1f6feb,stroke-width:1px
    style B0 fill:#ffe3e3,stroke:#d94848,stroke-width:2px
    style DONE fill:#d9fbe1,stroke:#2f9e44,stroke-width:2px
    style COK fill:#d9fbe1,stroke:#2f9e44,stroke-width:2px
    style CKO fill:#fff0b3,stroke:#e0a800,stroke-width:2px
    style CERR fill:#ffe3e3,stroke:#d94848,stroke-width:2px
